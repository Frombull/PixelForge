    "@jaames/iro": "^5.5.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "p5": "^2.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "three": "^0.183.2",
    "three-viewport-gizmo": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/p5": "^1.7.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
